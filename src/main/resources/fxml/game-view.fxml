<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.lulow.justtype.controller.GameController">

   <AnchorPane
           fx:id="rootPane"
           prefWidth="640" prefHeight="360"
           minWidth="640" minHeight="360"
           styleClass="root-pane">

      <AnchorPane
              prefWidth="640" prefHeight="38"
              AnchorPane.topAnchor="24"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0">

         <HBox
                 prefWidth="110" prefHeight="38"
                 alignment="CENTER"
                 styleClass="timer-pill"
                 AnchorPane.topAnchor="0"
                 AnchorPane.leftAnchor="258">

            <StackPane fx:id="timerPane" prefWidth="110" prefHeight="38">
               <Label
                       fx:id="timerLabel"
                       text="20"
                       alignment="CENTER"
                       styleClass="timer-label"
                       StackPane.alignment="CENTER"/>

            </StackPane>

         </HBox>

         <Label
                 fx:id="levelLabel"
                 styleClass="level-label"
                 AnchorPane.topAnchor="0"
                 AnchorPane.rightAnchor="36"
                 AnchorPane.bottomAnchor="0"/>

      </AnchorPane>

      <HBox
              fx:id="wordDisplay"
              alignment="CENTER"
              AnchorPane.topAnchor="78"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"/>

      <StackPane
              prefHeight="48"
              AnchorPane.topAnchor="198"
              AnchorPane.leftAnchor="144"
              AnchorPane.rightAnchor="144">

         <TextField
                 fx:id="inputField"
                 prefHeight="48"
                 maxWidth="Infinity"
                 styleClass="input-field"
                 onAction="#onEnterPressed"/>

         <Button
                 fx:id="submitButton"
                 prefHeight="30" prefWidth="34"
                 styleClass="submit-button"
                 StackPane.alignment="CENTER_RIGHT"
                 onAction="#onSubmitButtonClicked">
            <StackPane.margin>
               <Insets right="8"/>
            </StackPane.margin>
            <graphic>
               <Label
                       text=""
                       styleClass="submit-button-icon"/>
            </graphic>
         </Button>

      </StackPane>

   </AnchorPane>

</StackPane>
